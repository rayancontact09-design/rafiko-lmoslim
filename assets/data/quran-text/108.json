{
  "ayahs": [
    {
      "number": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ إِنَّآ أَعْطَيْنَـٰكَ ٱلْكَوْثَرَ"
    },
    {
      "number": 2,
      "text": "فَصَلِّ لِرَبِّكَ وَٱنْحَرْ"
    },
    {
      "number": 3,
      "text": "إِنَّ شَانِئَكَ هُوَ ٱلْأَبْتَرُ"
    }
  ]
}
