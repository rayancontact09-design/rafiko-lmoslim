  { "number": 108, "name": "الكوثر", "englishName": "Al-Kawthar", "englishTranslation": "The Abundance", "revelationType": "meccan", "ayahCount": 3, "hasFullText": false, "ayahs": [] },
  { "number": 109, "name": "الكافرون", "englishName": "Al-Kafirun", "englishTranslation": "The Disbelievers", "revelationType": "meccan", "ayahCount": 6, "hasFullText": false, "ayahs": [] },
  { "number": 110, "name": "النصر", "englishName": "An-Nasr", "englishTranslation": "The Divine Support", "revelationType": "medinan", "ayahCount": 3, "hasFullText": false, "ayahs": [] },
  { "number": 111, "name": "المسد", "englishName": "Al-Masad", "englishTranslation": "The Palm Fiber", "revelationType": "meccan", "ayahCount": 5, "hasFullText": false, "ayahs": [] },
  { "number": 112, "name": "الإخلاص", "englishName": "Al-Ikhlas", "englishTranslation": "The Sincerity", "revelationType": "meccan", "ayahCount": 4, "hasFullText": true, "ayahs": [
    { "number": 1, "text": "قُلْ هُوَ اللَّهُ أَحَدٌ" },
    { "number": 2, "text": "اللَّهُ الصَّمَدُ" },
    { "number": 3, "text": "لَمْ يَلِدْ وَلَمْ يُولَدْ" },
    { "number": 4, "text": "وَلَمْ يَكُنْ لَهُ كُفُوًا أَحَدٌ" }
  ] },
  { "number": 113, "name": "الفلق", "englishName": "Al-Falaq", "englishTranslation": "The Daybreak", "revelationType": "meccan", "ayahCount": 5, "hasFullText": true, "ayahs": [
    { "number": 1, "text": "قُلْ أَعُوذُ بِرَبِّ الْفَلَقِ" },
    { "number": 2, "text": "مِنْ شَرِّ مَا خَلَقَ" },
    { "number": 3, "text": "وَمِنْ شَرِّ غَاسِقٍ إِذَا وَقَبَ" },
    { "number": 4, "text": "وَمِنْ شَرِّ النَّفَّاثَاتِ فِي الْعُقَدِ" },
    { "number": 5, "text": "وَمِنْ شَرِّ حَاسِدٍ إِذَا حَسَدَ" }
  ] },
  { "number": 114, "name": "الناس", "englishName": "An-Nas", "englishTranslation": "Mankind", "revelationType": "meccan", "ayahCount": 6, "hasFullText": true, "ayahs": [
    { "number": 1, "text": "قُلْ أَعُوذُ بِرَبِّ النَّاسِ" },
    { "number": 2, "text": "مَلِكِ النَّاسِ" },
    { "number": 3, "text": "إِلٰهِ النَّاسِ" },
    { "number": 4, "text": "مِنْ شَرِّ الْوَسْوَاسِ الْخَنَّاسِ" },
    { "number": 5, "text": "الَّذِي يُوَسْوِسُ فِي صُدُورِ النَّاسِ" },
    { "number": 6, "text": "مِنَ الْجِنَّةِ وَالنَّاسِ" }
  ] }
